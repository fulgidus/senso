{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coaching_simple_response",
  "title": "CoachingSimpleResponse",
  "description": "Non-colloquial structured response for API/machine consumers.",
  "type": "object",
  "required": ["affordability_score", "short_answer", "data_points"],
  "additionalProperties": false,
  "properties": {
    "affordability_score": {
      "type": "string",
      "enum": ["yes", "no", "conditional", "insufficient_data"],
      "description": "Direct affordability verdict"
    },
    "short_answer": {
      "type": "string",
      "description": "One sentence answer. No jargon."
    },
    "data_points": {
      "type": "array",
      "description": "Key numbers used in the assessment.",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" },
          "currency": { "type": "string" }
        }
      }
    },
    "condition": {
      "type": "string",
      "description": "If affordability_score is 'conditional', what condition must be met."
    }
  }
}
