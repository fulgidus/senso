#!/usr/bin/env sh
# Pre-push: full TypeScript type-check on the frontend.
# Catches type errors that per-file staged linting misses.
# Filters out dev-dependency type declaration errors (packages only in Docker).
cd fe || exit 1
ERRORS=$(npx tsc -b --noEmit 2>&1 | grep -v "Cannot find module '@marp-team/marp-core'" | grep -v "Cannot find module 'vite-plugin-pwa'" | grep "error TS" || true)
if [ -n "$ERRORS" ]; then
  echo "TypeScript errors found:"
  echo "$ERRORS"
  exit 1
fi
echo "TypeScript check passed."
