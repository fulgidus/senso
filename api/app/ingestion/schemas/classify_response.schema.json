{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "classify_response",
  "title": "ClassifyResponse",
  "type": "object",
  "required": ["document_type", "confidence"],
  "additionalProperties": false,
  "properties": {
    "document_type": {
      "type": "string",
      "enum": [
        "bank_statement",
        "payslip",
        "receipt",
        "invoice",
        "f24_tax_form",
        "road_fine",
        "certificato_unico",
        "utility_bill",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "reasoning": {
      "type": "string"
    }
  }
}
