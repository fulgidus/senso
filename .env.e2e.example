# E2E test environment - copy to .env.e2e and fill in values
# Load with: set -a && source .env.e2e && set +a && pnpm e2e

# Frontend URL (change to http://localhost:5173 for Vite dev server)
E2E_BASE_URL=http://localhost:3000

# Backend API URL
E2E_API_URL=http://localhost:8000

# Test user credentials - must exist in the running DB
# Run `bash scripts/seed-demo.sh` to create the demo user with these defaults
E2E_EMAIL=demo@sen.so
E2E_PASSWORD=demodemo!
