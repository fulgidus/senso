# .env.e2e.example - copy to .env.e2e and fill in values for E2E real-stack tests
# Used by docker-compose.test.yml overlay

# Required: token shared between docker-compose.test.yml, Playwright tests, and the API
INTERNAL_TOKEN=test-internal-token

# Optional: Playwright will use these if set
FRONTEND_URL=http://localhost:3001
API_URL=http://localhost:8000

# Postgres credentials (match docker-compose.yml defaults)
POSTGRES_USER=senso
POSTGRES_PASSWORD=senso
