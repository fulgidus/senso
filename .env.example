POSTGRES_USER=senso
POSTGRES_PASSWORD=senso
POSTGRES_DB=senso
DATABASE_URL=postgresql://senso:senso@postgres:5432/senso

JWT_SECRET=change-me-with-at-least-32-characters
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

FRONTEND_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:8000

# MinIO object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET=senso-uploads

# LLM providers
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# OpenRouter model selection (optional — defaults shown)
# Fast/cheap:   mistralai/mistral-small-3.1-24b-instruct
# Balanced:     mistralai/mistral-small-24b-instruct-2501
# High quality: qwen/qwen3-235b-a22b-2507  (slow — not recommended for demo)
# Vision alt:   meta-llama/llama-4-scout
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEXT_MODEL=mistralai/mistral-small-3.1-24b-instruct
OPENROUTER_VISION_MODEL=mistralai/mistral-small-3.1-24b-instruct

# Debug toggles — set to false (or omit) for production; true for development/demo
# LLM_DEBUG=true enables debug payload in POST /coaching/chat response (backend restart needed)
# VITE_SHOW_REASONING=true shows "Ragionamento usato" collapsible in chat UI (frontend rebuild needed)
# VITE_LLM_DEBUG=true shows full LLM diagnostics panel per message in chat UI (frontend rebuild needed)
LLM_DEBUG=false
VITE_SHOW_REASONING=false
VITE_LLM_DEBUG=false